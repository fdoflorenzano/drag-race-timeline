---
import * as d3 from "d3";

import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import data from "../content/datasets/cumulative-contestants.json";

type Row = {
  month: string;
  cumulativeContestants: number;
  cumulativeReturnedContestants: number;
};

const rows = data as Row[];

// Parse "YYYY-MM" into a Date at the first of the month.
const parseMonth = d3.timeParse("%Y-%m");
const points = rows
  .map((r) => ({
    date: parseMonth(r.month) as Date,
    contestants: r.cumulativeContestants,
    returned: r.cumulativeReturnedContestants,
  }))
  .filter((p) => p.date);

// SVG geometry.
const width = 900;
const height = 460;
const margin = { top: 24, right: 24, bottom: 40, left: 48 };
const innerWidth = width - margin.left - margin.right;
const innerHeight = height - margin.top - margin.bottom;

const x = d3
  .scaleTime()
  .domain(d3.extent(points, (p) => p.date) as [Date, Date])
  .range([0, innerWidth]);

const y = d3
  .scaleLinear()
  .domain([0, d3.max(points, (p) => p.contestants) ?? 0])
  .nice()
  .range([innerHeight, 0]);

type Point = (typeof points)[number];

// Share of the total made up by returning contestants, 0–100.
const share = (p: Point) =>
  p.contestants ? (p.returned / p.contestants) * 100 : 0;

// Relative-mode scale: the total is always 100%, returning is its share.
const yRel = d3.scaleLinear().domain([0, 100]).range([innerHeight, 0]);

const areaFor = (accessor: (p: Point) => number) =>
  d3
    .area<Point>()
    .x((p) => x(p.date))
    .y0(innerHeight)
    .y1((p) => accessor(p))
    .curve(d3.curveMonotoneX)(points) ?? "";

const lineFor = (accessor: (p: Point) => number) =>
  d3
    .line<Point>()
    .x((p) => x(p.date))
    .y((p) => accessor(p))
    .curve(d3.curveMonotoneX)(points) ?? "";

// Absolute (counts) geometry.
const contestantsArea = areaFor((p) => y(p.contestants));
const returnedArea = areaFor((p) => y(p.returned));
const contestantsLine = lineFor((p) => y(p.contestants));
const returnedLine = lineFor((p) => y(p.returned));

// Relative (percentage of total) geometry.
const totalRelArea = areaFor(() => yRel(100));
const returnedRelArea = areaFor((p) => yRel(share(p)));
const totalRelLine = lineFor(() => yRel(100));
const returnedRelLine = lineFor((p) => yRel(share(p)));

const xTicks = x.ticks(d3.timeYear.every(2)!).map((t) => ({
  x: x(t),
  label: d3.timeFormat("%Y")(t),
}));
const yTicks = y.ticks(6).map((t) => ({ y: y(t), label: `${t}` }));
const yRelTicks = yRel.ticks(5).map((t) => ({ y: yRel(t), label: `${t}%` }));

const last = points[points.length - 1];

const monthLabel = d3.timeFormat("%B %Y");

// Months where the returning percentage reaches a new all-time high.
let maxPct = 0;
const recordPoints = points
  .map((p) => {
    const pct = p.contestants ? (p.returned / p.contestants) * 100 : 0;
    return { p, pct };
  })
  .filter(({ pct }) => {
    if (pct > maxPct) {
      maxPct = pct;
      return true;
    }
    return false;
  })
  .map(({ p, pct }) => ({
    cx: x(p.date),
    cy: y(p.returned),
    cyRel: yRel(pct),
    label: monthLabel(p.date),
    pct,
  }));

const currentPct = last.contestants
  ? (last.returned / last.contestants) * 100
  : 0;
// recordPoints is chronological, so the last record is the all-time peak.
const peakRecord = recordPoints[recordPoints.length - 1];

// Pixel positions (in inner-chart coordinates) for the client-side tooltip.
const tooltipData = {
  margin,
  innerWidth,
  innerHeight,
  points: points.map((p) => ({
    px: x(p.date),
    pyContestants: y(p.contestants),
    pyReturned: y(p.returned),
    pyContestantsRel: yRel(100),
    pyReturnedRel: yRel(share(p)),
    label: monthLabel(p.date),
    contestants: p.contestants,
    returned: p.returned,
    pct: share(p),
  })),
};
---

<Layout title="Cumulative Contestants — Drag Race Timeline">
  <main>
    <Nav />
    <header>
      <h1>Cumulative <span class="emphasis">Contestants</span></h1>
    </header>

    <p class="paragraph">
      Total drag artists to have ever appeared on a Drag Race stage, compared
      against the cumulative number of <em>returning</em> contestants — queens who
      came back for another season. As of {last.date.getFullYear()}, {
        last.contestants
      } contestants have competed, {last.returned} of those returning ({
        currentPct.toFixed(1)
      }%). That share peaked at {peakRecord.pct.toFixed(1)}% in {
        peakRecord.label
      }.
    </p>

    <figure class="chart">
      <div class="modeToggle" role="group" aria-label="Chart value mode">
        <button
          type="button"
          class="modeBtn"
          data-mode="abs"
          aria-pressed="true"
        >
          Counts
        </button>
        <button
          type="button"
          class="modeBtn"
          data-mode="rel"
          aria-pressed="false"
        >
          % of total
        </button>
      </div>

      <svg
        viewBox={`0 0 ${width} ${height}`}
        role="img"
        aria-label="Area chart of cumulative contestants over time"
      >
        <defs>
          <linearGradient id="fillContestants" x1="0" x2="0" y1="0" y2="1">
            <stop
              offset="0%"
              stop-color="var(--color-longest-streak)"
              stop-opacity="0.6"></stop>
            <stop
              offset="100%"
              stop-color="var(--color-longest-streak)"
              stop-opacity="0.05"></stop>
          </linearGradient>
          <linearGradient id="fillReturned" x1="0" x2="0" y1="0" y2="1">
            <stop
              offset="0%"
              stop-color="var(--color-streak)"
              stop-opacity="0.75"></stop>
            <stop
              offset="100%"
              stop-color="var(--color-streak)"
              stop-opacity="0.1"></stop>
          </linearGradient>
        </defs>

        <g transform={`translate(${margin.left}, ${margin.top})`}>
          <g class="axis axis-abs">
            {
              yTicks.map((t) => (
                <g class="gridline" transform={`translate(0, ${t.y})`}>
                  <line x1="0" x2={innerWidth} />
                  <text x="-10" dy="0.32em" text-anchor="end">
                    {t.label}
                  </text>
                </g>
              ))
            }
          </g>
          <g class="axis axis-rel">
            {
              yRelTicks.map((t) => (
                <g class="gridline" transform={`translate(0, ${t.y})`}>
                  <line x1="0" x2={innerWidth} />
                  <text x="-10" dy="0.32em" text-anchor="end">
                    {t.label}
                  </text>
                </g>
              ))
            }
          </g>

          {
            xTicks.map((t) => (
              <text
                class="axisLabel"
                x={t.x}
                y={innerHeight + 24}
                text-anchor="middle"
              >
                {t.label}
              </text>
            ))
          }

          <g class="series">
            <path
              class="morph areaTotal"
              d={contestantsArea}
              data-abs={contestantsArea}
              data-rel={totalRelArea}
              fill="url(#fillContestants)"></path>
            <path
              class="morph lineTotal"
              d={contestantsLine}
              data-abs={contestantsLine}
              data-rel={totalRelLine}
              fill="none"
              stroke="var(--color-longest-streak)"
              stroke-width="2"></path>

            <path
              class="morph areaReturned"
              d={returnedArea}
              data-abs={returnedArea}
              data-rel={returnedRelArea}
              fill="url(#fillReturned)"></path>
            <path
              class="morph lineReturned"
              d={returnedLine}
              data-abs={returnedLine}
              data-rel={returnedRelLine}
              fill="none"
              stroke="var(--color-streak)"
              stroke-width="2"></path>

            {
              recordPoints.map((r) => (
                <circle
                  class="recordDot"
                  cx={r.cx}
                  cy={r.cy}
                  data-cy-abs={r.cy}
                  data-cy-rel={r.cyRel}
                  r="4"
                >
                  <title>
                    {r.label}: new high of {r.pct.toFixed(1)}% returning
                  </title>
                </circle>
              ))
            }
          </g>

          <g class="focus">
            <line class="focusLine" y1="0" y2={innerHeight}></line>
            <circle class="focusDot focusDotContestants" r="4"></circle>
            <circle class="focusDot focusDotReturned" r="4"></circle>
          </g>

          <rect
            class="overlay"
            width={innerWidth}
            height={innerHeight}
            fill="transparent"></rect>
        </g>
      </svg>

      <div class="tooltip" hidden role="status">
        <p class="tooltipDate"></p>
        <p class="tooltipRow">
          <span
            class="swatch"
            style={{ background: "var(--color-longest-streak)" }}></span>
          <span class="tooltipLabel">Total</span>
          <span class="tooltipValue tooltipTotal"></span>
          <span class="tooltipPct tooltipTotalPct"></span>
        </p>
        <p class="tooltipRow">
          <span class="swatch" style={{ background: "var(--color-streak)" }}
          ></span>
          <span class="tooltipLabel">Returning</span>
          <span class="tooltipValue tooltipReturned"></span>
          <span class="tooltipPct tooltipReturnedPct"></span>
        </p>
      </div>

      <script
        type="application/json"
        id="chartData"
        set:html={JSON.stringify(tooltipData)}
      />
      <script>
        type TooltipPoint = {
          px: number;
          pyContestants: number;
          pyReturned: number;
          pyContestantsRel: number;
          pyReturnedRel: number;
          label: string;
          contestants: number;
          returned: number;
          pct: number;
        };
        type ChartData = {
          margin: { top: number; right: number; bottom: number; left: number };
          innerWidth: number;
          innerHeight: number;
          points: TooltipPoint[];
        };

        const dataEl = document.getElementById("chartData");
        const figure = document.querySelector<HTMLElement>(".chart");
        const svg = figure?.querySelector("svg");
        const overlay = svg?.querySelector<SVGRectElement>(".overlay");
        const focus = svg?.querySelector<SVGGElement>(".focus");
        const focusLine = svg?.querySelector<SVGLineElement>(".focusLine");
        const dotTotal = svg?.querySelector<SVGCircleElement>(
          ".focusDotContestants",
        );
        const dotReturned =
          svg?.querySelector<SVGCircleElement>(".focusDotReturned");
        const tooltip = figure?.querySelector<HTMLElement>(".tooltip");

        if (
          dataEl &&
          figure &&
          svg &&
          overlay &&
          focus &&
          focusLine &&
          dotTotal &&
          dotReturned &&
          tooltip
        ) {
          const { margin, points } = JSON.parse(
            dataEl.textContent || "{}",
          ) as ChartData;

          const tDate = tooltip.querySelector<HTMLElement>(".tooltipDate")!;
          const tTotal = tooltip.querySelector<HTMLElement>(".tooltipTotal")!;
          const tTotalPct =
            tooltip.querySelector<HTMLElement>(".tooltipTotalPct")!;
          const tReturned =
            tooltip.querySelector<HTMLElement>(".tooltipReturned")!;
          const tReturnedPct =
            tooltip.querySelector<HTMLElement>(".tooltipReturnedPct")!;

          let mode: "abs" | "rel" = "abs";
          let lastClientX: number | null = null;

          // Find the point whose pixel-x is nearest the cursor's inner-x.
          const nearest = (innerX: number) => {
            let lo = 0;
            let hi = points.length - 1;
            while (lo < hi) {
              const mid = (lo + hi) >> 1;
              if (points[mid].px < innerX) lo = mid + 1;
              else hi = mid;
            }
            const prev = points[Math.max(0, lo - 1)];
            const curr = points[lo];
            return innerX - prev.px < curr.px - innerX ? prev : curr;
          };

          const move = (clientX: number) => {
            lastClientX = clientX;
            const rect = svg.getBoundingClientRect();
            // Map screen px -> SVG viewBox px (viewBox width is fixed at build).
            const vb = svg.viewBox.baseVal;
            const scale = vb.width / rect.width;
            const svgX = (clientX - rect.left) * scale;
            const innerX = svgX - margin.left;

            const p = nearest(innerX);
            const totalY =
              mode === "rel" ? p.pyContestantsRel : p.pyContestants;
            const returnedY = mode === "rel" ? p.pyReturnedRel : p.pyReturned;

            focus.classList.add("visible");
            focusLine.setAttribute("x1", `${p.px}`);
            focusLine.setAttribute("x2", `${p.px}`);
            dotTotal.setAttribute("cx", `${p.px}`);
            dotTotal.setAttribute("cy", `${totalY}`);
            dotReturned.setAttribute("cx", `${p.px}`);
            dotReturned.setAttribute("cy", `${returnedY}`);

            // Show both counts and percentages regardless of mode.
            tDate.textContent = p.label;
            tTotal.textContent = `${p.contestants}`;
            tTotalPct.textContent = "100%";
            tReturned.textContent = `${p.returned}`;
            tReturnedPct.textContent = `${p.pct.toFixed(1)}%`;

            // Position tooltip near the point, flipping to stay in view.
            tooltip.removeAttribute("hidden");
            const dotScreenX = rect.left + (margin.left + p.px) / scale;
            const relX = dotScreenX - rect.left;
            const flip = relX > rect.width / 2;
            tooltip.classList.toggle("flip", flip);
            tooltip.style.left = `${relX}px`;
          };

          const onMove = (e: PointerEvent) => move(e.clientX);
          overlay.addEventListener("pointermove", onMove);
          overlay.addEventListener("pointerdown", onMove);
          overlay.addEventListener("pointerleave", () => {
            focus.classList.remove("visible");
            tooltip.setAttribute("hidden", "");
          });

          // Interpolate between two numbers-with-same-structure strings.
          // The abs/rel "d" paths share identical command structure (same
          // generator + points), so only the embedded numbers differ.
          const numRe = /-?\d*\.?\d+(?:e[-+]?\d+)?/gi;
          const makeTween = (from: string, to: string) => {
            const a = (from.match(numRe) || []).map(Number);
            const b = (to.match(numRe) || []).map(Number);
            const sep = to.split(numRe);
            return (t: number) => {
              let out = sep[0];
              for (let i = 0; i < b.length; i++) {
                const start = a[i] ?? b[i];
                out += start + (b[i] - start) * t + sep[i + 1];
              }
              return out;
            };
          };

          const easeInOut = (t: number) =>
            t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

          const morphPaths = svg.querySelectorAll<SVGPathElement>(".morph");
          const recordDots =
            svg.querySelectorAll<SVGCircleElement>(".recordDot");
          const legendLabels =
            figure.querySelectorAll<HTMLElement>(".legendLabel");

          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          let animId = 0;
          const animateTo = (target: "abs" | "rel") => {
            cancelAnimationFrame(animId);

            const pathTweens = Array.from(morphPaths).map((path) => ({
              path,
              tween: makeTween(
                path.getAttribute("d") || "",
                path.dataset[target] || "",
              ),
            }));
            const dotTweens = Array.from(recordDots).map((dot) => {
              const from = Number(dot.getAttribute("cy"));
              const to = Number(
                target === "rel" ? dot.dataset.cyRel : dot.dataset.cyAbs,
              );
              return { dot, from, to };
            });

            const apply = (t: number) => {
              for (const { path, tween } of pathTweens)
                path.setAttribute("d", tween(t));
              for (const { dot, from, to } of dotTweens)
                dot.setAttribute("cy", `${from + (to - from) * t}`);
            };

            if (reduceMotion) {
              apply(1);
              return;
            }

            const duration = 550;
            let startTs = 0;
            const step = (ts: number) => {
              if (!startTs) startTs = ts;
              const t = Math.min(1, (ts - startTs) / duration);
              apply(easeInOut(t));
              if (t < 1) animId = requestAnimationFrame(step);
            };
            animId = requestAnimationFrame(step);
          };

          // Mode toggle: morph the series, crossfade the axis, swap labels.
          const buttons =
            figure.querySelectorAll<HTMLButtonElement>(".modeBtn");
          buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
              const next = btn.dataset.mode === "rel" ? "rel" : "abs";
              if (next === mode) return;
              mode = next;
              figure.classList.toggle("relative", mode === "rel");
              buttons.forEach((b) =>
                b.setAttribute("aria-pressed", b === btn ? "true" : "false"),
              );
              legendLabels.forEach((el) => {
                el.textContent = el.dataset[mode] || el.textContent;
              });
              animateTo(mode);
              if (lastClientX !== null && !tooltip.hasAttribute("hidden"))
                move(lastClientX);
            });
          });
        }
      </script>

      <figcaption class="legend">
        <span class="key">
          <span
            class="swatch"
            style={{ background: "var(--color-longest-streak)" }}></span>
          <span
            class="legendLabel legendTotal"
            data-abs="Cumulative contestants"
            data-rel="Total (100%)">Cumulative contestants</span
          >
        </span>
        <span class="key">
          <span class="swatch" style={{ background: "var(--color-streak)" }}
          ></span>
          <span
            class="legendLabel legendReturned"
            data-abs="Cumulative returning contestants"
            data-rel="Returning share of total"
            >Cumulative returning contestants</span
          >
        </span>
        <span class="key">
          <span
            class="swatch swatchDot"
            style={{ background: "var(--color-current-streak)" }}></span>
          New high in % returning
        </span>
      </figcaption>
    </figure>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(960px, 100%);
    margin: 0 auto;
    padding: 2rem 1rem;
    color: white;
  }

  main header {
    align-self: start;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    max-width: 10ch;
  }

  .emphasis {
    font-weight: normal;
  }

  .paragraph {
    align-self: start;
    max-width: 40ch;
    font-size: 0.8rem;
  }

  .paragraph a,
  .paragraph a:visited {
    color: var(--color-streak);
    font-weight: bold;
  }

  .chart {
    position: relative;
    width: 100%;
    margin: 1.5rem 0;
  }

  .chart svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .modeToggle {
    display: inline-flex;
    gap: 0;
    margin-bottom: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }

  .modeBtn {
    background: transparent;
    color: var(--color-text);
    border: none;
    padding: 0.3rem 0.9rem;
    font-size: 0.5rem;
    cursor: pointer;
    opacity: 0.6;
    transition:
      background 0.15s ease,
      opacity 0.15s ease;
  }

  .modeBtn[aria-pressed="true"] {
    background: var(--color-streak);
    opacity: 1;
  }

  /* Counts axis shows by default; crossfade to the % axis in relative mode.
     The series paths themselves morph via JS rather than swapping. */
  .axis {
    transition: opacity 0.4s ease;
  }

  .axis-rel {
    opacity: 0;
  }

  .chart.relative .axis-abs {
    opacity: 0;
  }

  .chart.relative .axis-rel {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .axis {
      transition: none;
    }
  }

  .overlay {
    cursor: crosshair;
  }

  .focus {
    opacity: 0;
    transition: opacity 0.1s ease;
    pointer-events: none;
  }

  .focus.visible {
    opacity: 1;
  }

  .focusLine {
    stroke: var(--color-text);
    stroke-width: 1;
    stroke-dasharray: 3 3;
    opacity: 0.5;
  }

  .focusDot {
    stroke: var(--color-background);
    stroke-width: 2;
  }

  .focusDotContestants {
    fill: var(--color-longest-streak);
  }

  .focusDotReturned {
    fill: var(--color-streak);
  }

  .recordDot {
    fill: var(--color-current-streak);
    stroke: var(--color-background);
    stroke-width: 1.5;
  }

  .tooltip {
    position: absolute;
    top: 0;
    transform: translateX(12px);
    pointer-events: none;
    background: rgba(31, 34, 50, 0.95);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.5rem 0.65rem;
    font-size: 0.5rem;
    line-height: 1.4;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
  }

  .tooltip.flip {
    transform: translateX(-100%) translateX(-12px);
  }

  .tooltipDate {
    margin: 0 0 0.35rem;
    font-weight: bold;
  }

  .tooltipRow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
  }

  .tooltipLabel {
    opacity: 0.7;
  }

  .tooltipValue {
    margin-left: auto;
    font-weight: bold;
    font-variant-numeric: tabular-nums;
  }

  .tooltipPct {
    min-width: 3.4em;
    text-align: right;
    color: var(--color-current-streak);
    font-weight: bold;
    font-variant-numeric: tabular-nums;
  }

  .gridline line {
    stroke: var(--color-border);
    stroke-width: 1;
  }

  .gridline text,
  .axisLabel {
    fill: var(--color-text);
    font-size: 11px;
    opacity: 0.6;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-size: 0.5rem;
    margin-top: 0.75rem;
  }

  .key {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .swatch {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    display: inline-block;
  }

  .swatchDot {
    border-radius: 50%;
  }
</style>
