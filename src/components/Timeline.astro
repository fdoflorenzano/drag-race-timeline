---
import moment from "moment";

import Episode from "./Episode";

import type { ExtendedEpisode, GeneralStreak, Streak } from "../lib/data";
import { weeksArray } from "../lib/weeks";

interface Props {
  rows: number;
  tracks: number;
  episodes: ExtendedEpisode[];
  streaks: Streak[];
  generalStreaks: GeneralStreak[];
}

const { rows, tracks, episodes, streaks, generalStreaks } = Astro.props;

const weekCount = weeksArray.length;

// One entry per week row, with the Monday that anchors it. weeksArray is
// chronological (index 0 = oldest); the grid stacks newest at the top.
const axisRows = weeksArray.map((d, i) => {
  const monday = moment.utc().isoWeekYear(d.year).isoWeek(d.week).isoWeekday(1);
  // Band by ISO week-year (the grid's native unit) to avoid an orphan band at
  // the boundary; month names still come from the Monday.
  return { i, monday, year: d.year, month: monday.month() };
});

// Map a chronological index to its subgrid row (row 1 = newest, at the top).
const subRow = (i: number) => weekCount - i;

// Month ticks: the first (oldest) week of each month, so the label sits where
// the month begins; its bottom border doubles as the boundary with the month
// below (older) it.
const axisMonths = axisRows.filter(
  (r, idx) => idx === 0 || r.month !== axisRows[idx - 1].month,
);
const monthStartRows = new Set(axisMonths.map((r) => r.i));

// Year bands: consecutive runs of the same calendar year, each spanning its rows.
const axisYears: { year: number; startI: number; endI: number }[] = [];
for (const r of axisRows) {
  const last = axisYears[axisYears.length - 1];
  if (last && last.year === r.year) last.endI = r.i;
  else axisYears.push({ year: r.year, startI: r.i, endI: r.i });
}
---

<div
  class="timeline"
  style={{
    "--row-number": `${rows}`,
    "--track-number": `${tracks}`,
  }}
>
  <p class="legend" style={{ gridRow: 1, gridColumn: 1, justifySelf: "end" }}>
    Date
  </p>
  <p
    class="legend"
    style={{
      gridRow: 1,
      gridColumn: `2 / span ${tracks - 1}`,
      justifySelf: "center",
    }}
  >
    Seasons
  </p>
  <p
    class="legend"
    style={{ gridRow: 1, gridColumn: tracks + 1, justifySelf: "center" }}
  >
    Streaks
  </p>
  {
    weeksArray.map((_d, i) => (
      <div
        class={"gridRow" + (monthStartRows.has(i) ? " monthStart" : "")}
        style={{
          gridColumn: `2 / span ${tracks - 1}`,
          gridRow: `${1 + weekCount - i} / span 1`,
        }}
      />
    ))
  }

  <div class="axis" style={{ gridRow: `2 / span ${weekCount}` }}>
    {
      axisYears.map((y) => (
        <div
          class="yearBlock"
          style={{
            gridColumn: 1,
            gridRow: `${subRow(y.endI)} / span ${y.endI - y.startI + 1}`,
          }}
        >
          <span class="axisYear">{y.year}</span>
        </div>
      ))
    }
    {
      axisMonths.map((m) => (
        <p
          class="axisMonth"
          style={{ gridColumn: 2, gridRow: `${subRow(m.i)} / span 1` }}
        >
          {m.monday.format("MMM")}
        </p>
      ))
    }
  </div>

  {
    episodes.map((d) => (
      <Episode
        client:visible
        style={{
          gridColumn: `${2 + d.xOffset} / span 1`,
          gridRow: `${2 + weeksArray.length - d.week} / span 1`,
        }}
        episode={d}
      />
    ))
  }

  {
    streaks.map((d) => (
      <div
        class="streak"
        style={{
          "--label-offset": 0,
          gridColumn: `${2 + d.episodes[0].xOffset} / span 1`,
          gridRow: `${1 + weeksArray.length - d.end + 1} / span ${d.end - d.start + 1}`,
        }}
        data-season={d.season}
      >
        <div
          class="streakLine"
          style={{
            borderRadius: d.unfinished
              ? `0 0 var(--col-width) var(--col-width)`
              : `var(--col-width)`,
          }}
        />
        <p
          class="streakLabel"
          style={{
            "--label-offset": d.unfinished
              ? "0px"
              : "calc(var(--col-width) / 3)",
          }}
        >
          {d.season}
        </p>
      </div>
    ))
  }

  {
    generalStreaks.map((d) => (
      <div
        class={
          "streak generalStreak" +
          (d.isCurrent ? " currentStreak" : "") +
          (d.isLongest ? " longestStreak" : "")
        }
        style={{
          gridColumn: `${tracks + 1} / span 1`,
          gridRow: `${1 + weeksArray.length - d.end + 1} / span ${d.end - d.start + 1}`,
        }}
      >
        <div class="streakLine" />
        <p
          class="streakLabel"
          style={{
            "--label-offset": "calc(var(--col-width) / 3)",
          }}
        >
          {1 + d.end - d.start} weeks
        </p>
      </div>
    ))
  }
</div>

<style>
  .timeline {
    position: relative;
    display: grid;
    grid-template-columns: [labels] 1fr repeat(
        var(--track-number),
        var(--col-width)
      );
    grid-template-rows: repeat(var(--row-number), var(--col-width));
    gap: 0 var(--gap);
    margin-bottom: 3rem;

    -webkit-touch-callout: none;
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  }

  .legend {
    user-select: none;
    margin: 0 0 0.4rem 0;
    font-size: 0.5rem;
    align-self: end;
  }

  .gridRow {
    user-select: none;
    border-style: solid;
    border-width: 1px;

    border-color: var(--color-border);
  }

  .gridRow + .gridRow {
    border-width: 1px 1px 0 1px;
  }

  .gridRow.monthStart {
    border-bottom-width: 1px;
    border-bottom-color: rgba(240, 239, 244, 0.22);
  }

  .axis {
    user-select: none;
    grid-column: labels;
    justify-self: end;
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: subgrid;
    column-gap: 0.5rem;
  }

  .yearBlock {
    grid-column: 1;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .axisYear {
    position: sticky;
    top: 0.5rem;
    margin: 0;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .axisMonth {
    grid-column: 2;
    margin: 0;
    align-self: center;
    justify-self: end;
    font-size: 0.5rem;
    text-align: end;
    opacity: 0.55;
  }

  @media (max-width: 500px) {
    .axisYear {
      font-size: 0.55rem;
    }

    .axisMonth {
      font-size: 0.4rem;
    }
  }

  .streak {
    user-select: none;
    position: relative;
    overflow-x: visible;
  }

  .streakLine {
    user-select: none;
    height: 100%;
    background: var(--color-streak);
  }

  .generalStreak .streakLine {
    background: var(--color-general-streak);
    border-radius: var(--col-width);
  }

  .generalStreak.longestStreak .streakLine {
    background: var(--color-longest-streak);
  }

  .generalStreak.currentStreak .streakLine {
    background: var(--color-current-streak);
  }

  .streakLabel {
    user-select: none;
    position: absolute;
    left: 0;
    top: 0;
    margin: 0;
    font-size: 0.6rem;
    transform-origin: 0 0;
    width: max-content;
    transform: rotate(90deg) translateX(calc(0.1rem + var(--label-offset)))
      translateY(calc(-1 * (var(--col-width) + 0.8rem)));
  }

  @media (max-width: 500px) {
    .streakLabel {
      transform: rotate(90deg) translateX(calc(0.1rem + var(--label-offset)))
        translateY(calc(-1 * (var(--col-width) + 0.7rem)));
      font-size: 0.5rem;
    }
  }
</style>
