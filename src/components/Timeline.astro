---
import Episode from "./Episode";

import type { ExtendedEpisode, GeneralStreak, Streak } from "../lib/data";
import { buildSections, type SectionStreak } from "../lib/sections";

interface Props {
  tracks: number;
  episodes: ExtendedEpisode[];
  streaks: Streak[];
  generalStreaks: GeneralStreak[];
}

const { tracks, episodes, streaks, generalStreaks } = Astro.props;

const sections = buildSections(episodes, streaks, generalStreaks);

// Square off the cut edges of a streak segment so cross-year segments join up.
const streakRadius = (s: SectionStreak) => {
  const top = s.topRounded ? "var(--col-width)" : "0";
  const bottom = s.bottomRounded ? "var(--col-width)" : "0";
  return `${top} ${top} ${bottom} ${bottom}`;
};
---

<div class="timeline" style={{ "--track-number": `${tracks}` }}>
  <div class="legendRow">
    <p class="legend legendDate">Date</p>
    <p
      class="legend"
      style={{ gridColumn: `2 / span ${tracks - 1}`, justifySelf: "center" }}
    >
      Seasons
    </p>
    <p
      class="legend"
      style={{ gridColumn: tracks + 1, justifySelf: "center" }}
    >
      Streaks
    </p>
  </div>

  {
    sections.map((section) => (
      <section
        class="yearSection"
        style={{ "--row-count": `${section.rowCount}` }}
      >
        {Array.from({ length: section.rowCount }, (_, idx) => idx + 1).map(
          (r) => (
            <div
              class={
                "gridRow" + (section.monthStartRows.includes(r) ? " monthStart" : "")
              }
              style={{
                gridColumn: `2 / span ${tracks - 1}`,
                gridRow: `${r} / span 1`,
              }}
            />
          ),
        )}

        <div class="axis">
          <span class="axisYear">{section.year}</span>
          {section.monthLabels.map((m) => (
            <p class="axisMonth" style={{ gridRow: `${m.row} / span 1` }}>
              {m.label}
            </p>
          ))}
        </div>

        {section.episodes.map(({ episode, row }) => (
          <Episode
            client:visible
            style={{
              gridColumn: `${2 + episode.xOffset} / span 1`,
              gridRow: `${row} / span 1`,
            }}
            episode={episode}
          />
        ))}

        {section.streaks.map((s) => (
          <div
            class="streak"
            style={{
              gridColumn: `${2 + s.xOffset} / span 1`,
              gridRow: `${s.topRow} / span ${s.span}`,
            }}
            data-season={s.season}
          >
            <div class="streakLine" style={{ borderRadius: streakRadius(s) }} />
            {s.showLabel && (
              <p
                class="streakLabel"
                style={{
                  "--label-offset": s.unfinished
                    ? "0px"
                    : "calc(var(--col-width) / 3)",
                }}
              >
                {s.season}
              </p>
            )}
          </div>
        ))}

        {section.generalStreaks.map((s) => (
          <div
            class={
              "streak generalStreak" +
              (s.isCurrent ? " currentStreak" : "") +
              (s.isLongest ? " longestStreak" : "")
            }
            style={{
              gridColumn: `${tracks + 1} / span 1`,
              gridRow: `${s.topRow} / span ${s.span}`,
            }}
          >
            <div class="streakLine" style={{ borderRadius: streakRadius(s) }} />
            {s.showLabel && (
              <p
                class="streakLabel"
                style={{ "--label-offset": "calc(var(--col-width) / 3)" }}
              >
                {s.weeks} weeks
              </p>
            )}
          </div>
        ))}
      </section>
    ))
  }
</div>

<style>
  .timeline {
    --label-width: 3rem;
    position: relative;
    display: flex;
    flex-direction: column;
    width: max-content;
    margin-bottom: 3rem;

    -webkit-touch-callout: none;
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  }

  .legendRow,
  .yearSection {
    display: grid;
    grid-template-columns: [labels] var(--label-width) repeat(
        var(--track-number),
        var(--col-width)
      );
    gap: 0 var(--gap);
  }

  .yearSection {
    grid-template-rows: repeat(var(--row-count), var(--col-width));
    /* Skip layout/paint for years scrolled off-screen; reserve their height so
       the scrollbar stays accurate. */
    content-visibility: auto;
    contain-intrinsic-block-size: calc(var(--row-count) * var(--col-width));
  }

  .legend {
    user-select: none;
    margin: 0 0 0.4rem 0;
    font-size: 0.5rem;
    align-self: end;
  }

  .legendDate {
    grid-column: labels;
    justify-self: end;
  }

  .gridRow {
    user-select: none;
    border-style: solid;
    border-width: 1px;
    border-color: var(--color-border);
  }

  .gridRow + .gridRow {
    border-width: 1px 1px 0 1px;
  }

  .gridRow.monthStart {
    border-bottom-width: 1px;
    border-bottom-color: rgba(240, 239, 244, 0.22);
  }

  .axis {
    user-select: none;
    grid-column: labels;
    grid-row: 1 / -1;
    justify-self: end;
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: subgrid;
    column-gap: 0.5rem;
  }

  .axisYear {
    grid-column: 1;
    grid-row: 1 / -1;
    align-self: start;
    justify-self: center;
    position: sticky;
    top: 0.5rem;
    height: max-content;
    margin: 0;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .axisMonth {
    grid-column: 2;
    margin: 0;
    align-self: center;
    justify-self: end;
    font-size: 0.5rem;
    text-align: end;
    opacity: 0.55;
  }

  @media (max-width: 500px) {
    .axisYear {
      font-size: 0.55rem;
    }

    .axisMonth {
      font-size: 0.4rem;
    }
  }

  .streak {
    user-select: none;
    position: relative;
    overflow-x: visible;
  }

  .streakLine {
    user-select: none;
    height: 100%;
    background: var(--color-streak);
  }

  .generalStreak .streakLine {
    background: var(--color-general-streak);
  }

  .generalStreak.longestStreak .streakLine {
    background: var(--color-longest-streak);
  }

  .generalStreak.currentStreak .streakLine {
    background: var(--color-current-streak);
  }

  .streakLabel {
    user-select: none;
    position: absolute;
    left: 0;
    top: 0;
    margin: 0;
    font-size: 0.6rem;
    transform-origin: 0 0;
    width: max-content;
    transform: rotate(90deg) translateX(calc(0.1rem + var(--label-offset)))
      translateY(calc(-1 * (var(--col-width) + 0.8rem)));
  }

  @media (max-width: 500px) {
    .streakLabel {
      transform: rotate(90deg) translateX(calc(0.1rem + var(--label-offset)))
        translateY(calc(-1 * (var(--col-width) + 0.7rem)));
      font-size: 0.5rem;
    }
  }
</style>
